<div id="controls">
  <button class="ctrl-btn" id="prevBtn" onclick="nav(-1)" disabled>← PREV</button>
  <div style="display:flex; flex-direction:column; align-items:center; gap:8px; flex:1; max-width:500px;">
    <div class="progress-track"><div class="progress-fill" id="prog" style="width:7.69%"></div></div>
    <div class="dots" id="dots"></div>
  </div>
  <span class="slide-count" id="cnt">01 / 13</span>
  <button class="ctrl-btn" id="nextBtn" onclick="nav(1)">NEXT →</button>
</div>

<!-- Speaker Notes -->
<div id="notes-bar">
  <div id="notes-label">SPEAKER NOTES</div>
  <div id="notes-text"></div>
</div>

<div class="hint" id="hint">Press N for notes · F for fullscreen · ← → to navigate</div>

<script>
  const slides = document.querySelectorAll('.slide');
  const total = slides.length;
  let cur = 0;
  let notesVisible = false;

  // Build dots
  const dotsEl = document.getElementById('dots');
  slides.forEach((_, i) => {
    const d = document.createElement('div');
    d.className = 'dot' + (i === 0 ? ' active' : '');
    d.onclick = () => goTo(i);
    dotsEl.appendChild(d);
  });

  // Accent colors per slide
  const accents = {
    'E8302A': '#E8302A',
    'E8941A': '#E8941A',
    '2A6AE8': '#2A6AE8',
    '1AAE6A': '#1AAE6A',
    '7A8099': '#7A8099',
  };

  function goTo(n) {
    slides[cur].classList.remove('active');
    dotsEl.children[cur].classList.remove('active');
    cur = Math.max(0, Math.min(n, total - 1));
    slides[cur].classList.add('active');
    dotsEl.children[cur].classList.add('active');

    const pct = ((cur + 1) / total * 100).toFixed(2) + '%';
    document.getElementById('prog').style.width = pct;
    document.getElementById('cnt').textContent =
      String(cur + 1).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');
    document.getElementById('prevBtn').disabled = cur === 0;
    document.getElementById('nextBtn').disabled = cur === total - 1;

    // Update accent color on progress bar + dots
    const accentHex = slides[cur].dataset.accent || 'E8302A';
    const accentColor = '#' + accentHex;
    document.getElementById('prog').style.background = accentColor;
    document.querySelectorAll('.dot.active').forEach(d => d.style.background = accentColor);
    document.documentElement.style.setProperty('--current-accent', accentColor);

    // Speaker notes
    if (notesVisible) showNotes();

    // Fade hint after 5s
    document.getElementById('hint').style.opacity = '0.2';
  }

  function nav(dir) { goTo(cur + dir); }

  function showNotes() {
    const note = slides[cur].dataset.notes || '';
    document.getElementById('notes-text').textContent = note;
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') nav(1);
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')  nav(-1);
    if (e.key === 'n' || e.key === 'N') {
      notesVisible = !notesVisible;
      const bar = document.getElementById('notes-bar');
      bar.classList.toggle('visible', notesVisible);
      if (notesVisible) showNotes();
    }
    if (e.key === 'f' || e.key === 'F') {
      if (!document.fullscreenElement) document.documentElement.requestFullscreen();
      else document.exitFullscreen();
    }
  });

  // Hide hint after 6s
  setTimeout(() => document.getElementById('hint').style.transition = 'opacity 1s', 5000);
  setTimeout(() => document.getElementById('hint').style.opacity = '0', 6000);
</script>
</body>
</html>
