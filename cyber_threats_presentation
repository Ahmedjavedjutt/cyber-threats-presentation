<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Types of Cyber Threats | Academic Presentation</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #E8302A;
    --amber: #E8941A;
    --blue: #2A6AE8;
    --green: #1AAE6A;
    --dark: #0C0F1A;
    --dark2: #141829;
    --dark3: #1C2138;
    --border: rgba(255,255,255,0.09);
    --text: #E8EAF2;
    --muted: #7A8099;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'IBM Plex Sans', sans-serif;
    --font-mono: 'IBM Plex Mono', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    width: 100%; height: 100%;
    background: var(--dark);
    color: var(--text);
    font-family: var(--font-body);
    overflow: hidden;
    user-select: none;
  }

  /* ── PRESENTATION SHELL ── */
  #pres {
    width: 100vw; height: 100vh;
    display: flex; flex-direction: column;
    position: relative;
  }

  /* ── SLIDES ── */
  .slide {
    flex: 1;
    display: none;
    flex-direction: column;
    padding: 52px 72px 36px;
    position: relative;
    overflow: hidden;
    animation: slideIn .38s cubic-bezier(.22,.68,0,1.2) both;
  }
  .slide.active { display: flex; }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(18px) scale(.985); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Accent line top */
  .slide::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--accent, var(--red));
  }

  /* Background grid lines — subtle */
  .slide::after {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.015) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  .slide > * { position: relative; z-index: 1; }

  /* ── TYPOGRAPHY ── */
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent, var(--red));
    margin-bottom: 14px;
    display: flex; align-items: center; gap: 10px;
  }
  .eyebrow::after {
    content: '';
    flex: 1; height: 1px;
    background: linear-gradient(90deg, var(--accent, var(--red)), transparent);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.5vw, 52px);
    line-height: 1.1;
    font-weight: 900;
    margin-bottom: 12px;
    color: #fff;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    margin-bottom: 18px;
    color: #fff;
    line-height: 1.2;
  }

  h3 {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent, var(--red));
    margin-bottom: 10px;
  }

  p, li { font-size: 14px; line-height: 1.75; color: #B8C0D8; font-weight: 300; }
  strong { color: var(--text); font-weight: 500; }

  /* ── LAYOUT HELPERS ── */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; flex: 1; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 18px; }
  .col { display: flex; flex-direction: column; gap: 14px; }

  /* ── CARDS ── */
  .card {
    background: var(--dark2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 22px;
  }
  .card.accented {
    border-color: var(--accent, var(--red));
    background: rgba(255,255,255,.03);
  }
  .card.dark { background: rgba(0,0,0,.3); }

  /* ── STAT PILLS ── */
  .stats-row { display: flex; gap: 14px; margin-bottom: 20px; }
  .stat {
    flex: 1;
    background: var(--dark2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px;
    text-align: center;
  }
  .stat .num {
    font-family: var(--font-display);
    font-size: 32px; font-weight: 900;
    color: var(--accent, var(--red));
    display: block;
  }
  .stat .lbl {
    font-family: var(--font-mono);
    font-size: 10px; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--muted);
    margin-top: 4px; display: block;
  }

  /* ── BADGE ── */
  .badge {
    display: inline-block;
    padding: 4px 12px; border-radius: 20px;
    font-family: var(--font-mono);
    font-size: 10px; font-weight: 600;
    letter-spacing: 1.5px; text-transform: uppercase;
    margin-right: 6px; margin-bottom: 6px;
  }
  .badge-red   { background: rgba(232,48,42,.15); color: #F07070; border: 1px solid rgba(232,48,42,.3); }
  .badge-amber { background: rgba(232,148,26,.15); color: #F0C060; border: 1px solid rgba(232,148,26,.3); }
  .badge-blue  { background: rgba(42,106,232,.15); color: #80AAFF; border: 1px solid rgba(42,106,232,.3); }
  .badge-green { background: rgba(26,174,106,.15); color: #60E090; border: 1px solid rgba(26,174,106,.3); }
  .badge-gray  { background: rgba(255,255,255,.07); color: var(--muted); border: 1px solid var(--border); }

  /* ── CALLOUT ── */
  .callout {
    border-radius: 8px; padding: 14px 18px;
    font-size: 13px; line-height: 1.7;
    color: #B8C0D8;
  }
  .callout.danger { background: rgba(232,48,42,.08); border-left: 3px solid var(--red); }
  .callout.warn   { background: rgba(232,148,26,.08); border-left: 3px solid var(--amber); }
  .callout.info   { background: rgba(42,106,232,.08); border-left: 3px solid var(--blue); }
  .callout.ok     { background: rgba(26,174,106,.08); border-left: 3px solid var(--green); }
  .callout strong { color: var(--text); }

  /* ── TIMELINE ── */
  .timeline { position: relative; padding-left: 26px; }
  .timeline::before { content: ''; position: absolute; left: 7px; top: 8px; bottom: 8px; width: 1px; background: var(--border); }
  .tl { position: relative; margin-bottom: 16px; }
  .tl::before {
    content: ''; position: absolute; left: -22px; top: 5px;
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--accent, var(--red));
    box-shadow: 0 0 8px var(--accent, var(--red));
  }
  .tl-year { font-family: var(--font-mono); font-size: 10px; color: var(--accent, var(--red)); letter-spacing: 2px; }
  .tl-text { font-size: 13px; color: #B8C0D8; margin-top: 2px; }

  /* ── PROCESS FLOW ── */
  .flow { display: flex; flex-direction: column; gap: 6px; }
  .flow-step {
    background: var(--dark3);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 10px 14px;
    font-size: 13px;
    display: flex; align-items: center; gap: 10px;
  }
  .flow-step .fnum {
    font-family: var(--font-mono);
    font-size: 10px; font-weight: 600;
    color: var(--accent, var(--red));
    min-width: 22px;
  }
  .flow-arrow {
    text-align: center; color: var(--muted); font-size: 14px; line-height: 1;
    padding: 1px 0;
  }

  /* ── LIST ── */
  .list { list-style: none; }
  .list li {
    display: flex; gap: 10px; padding: 7px 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
    font-size: 13px; align-items: flex-start;
  }
  .list li::before { content: '→'; color: var(--accent, var(--red)); flex-shrink: 0; font-family: var(--font-mono); }

  /* ── NUMBERED TAKEAWAYS ── */
  .takeaway { display: flex; gap: 16px; margin-bottom: 16px; align-items: flex-start; }
  .tnum {
    width: 32px; height: 32px; border-radius: 6px;
    background: var(--accent, var(--red));
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 13px; font-weight: 600;
    color: var(--dark);
  }
  .takeaway p { font-size: 14px; padding-top: 4px; }

  /* ── TABLE ── */
  .cyber-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 8px; }
  .cyber-table th {
    text-align: left; padding: 10px 16px;
    font-family: var(--font-mono); font-size: 10px; font-weight: 600;
    letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
    border-bottom: 1px solid var(--border);
  }
  .cyber-table td { padding: 11px 16px; border-bottom: 1px solid rgba(255,255,255,.04); color: #B8C0D8; }
  .cyber-table tr:hover td { background: rgba(255,255,255,.025); }
  .cyber-table .col-red   { color: #F07070; font-weight: 500; }
  .cyber-table .col-amber { color: #F0C060; font-weight: 500; }
  .cyber-table .col-blue  { color: #80AAFF; font-weight: 500; }

  /* ── REF LIST ── */
  .ref { border-left: 2px solid var(--accent, var(--red)); padding: 6px 0 6px 14px; margin-bottom: 14px; }
  .ref-title { font-size: 13px; font-weight: 500; color: var(--text); }
  .ref-src   { font-family: var(--font-mono); font-size: 11px; color: var(--muted); margin-top: 3px; }

  /* ── CONTROLS BAR ── */
  #controls {
    flex-shrink: 0;
    display: flex; align-items: center;
    justify-content: space-between;
    padding: 12px 72px;
    border-top: 1px solid var(--border);
    background: rgba(0,0,0,.4);
    backdrop-filter: blur(6px);
    gap: 20px;
  }

  .ctrl-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    padding: 8px 22px;
    font-family: var(--font-mono);
    font-size: 12px; letter-spacing: 1px;
    cursor: pointer;
    transition: all .18s;
  }
  .ctrl-btn:hover { background: rgba(255,255,255,.07); border-color: rgba(255,255,255,.2); }
  .ctrl-btn:disabled { opacity: .3; cursor: default; }

  .progress-track {
    flex: 1; height: 2px;
    background: rgba(255,255,255,.07);
    border-radius: 2px; position: relative;
  }
  .progress-fill {
    height: 100%; border-radius: 2px;
    background: var(--current-accent, var(--red));
    transition: width .4s ease, background .4s ease;
  }

  .dots { display: flex; gap: 7px; }
  .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: rgba(255,255,255,.15);
    cursor: pointer; transition: all .2s;
  }
  .dot.active { background: var(--current-accent, var(--red)); transform: scale(1.4); }

  .slide-count {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--muted); letter-spacing: 2px; white-space: nowrap;
  }

  /* ── TITLE SLIDE SPECIAL ── */
  #s0 { justify-content: center; align-items: center; text-align: center; }
  #s0 h1 { font-size: clamp(40px, 5.5vw, 64px); margin-bottom: 18px; }
  .hero-sub { font-size: 18px; color: var(--muted); margin-bottom: 36px; letter-spacing: 2px; font-family: var(--font-mono); }

  /* GLOW ORBS on title */
  .orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); pointer-events: none; z-index: 0;
  }
  .orb1 { width: 300px; height: 300px; background: rgba(232,48,42,.12); top: -60px; left: -60px; }
  .orb2 { width: 250px; height: 250px; background: rgba(42,106,232,.10); bottom: -40px; right: 80px; }
  .orb3 { width: 200px; height: 200px; background: rgba(232,148,26,.08); top: 40%; left: 30%; }

  /* ── SPEAKER NOTES TOGGLE ── */
  #notes-bar {
    position: fixed; bottom: 60px; left: 0; right: 0;
    background: rgba(20,24,41,.96);
    border-top: 1px solid var(--border);
    padding: 14px 72px;
    font-size: 13px; color: var(--muted);
    display: none; z-index: 100;
    font-family: var(--font-body);
  }
  #notes-bar.visible { display: block; }
  #notes-label { font-family: var(--font-mono); font-size: 10px; color: var(--red); letter-spacing: 2px; margin-bottom: 5px; }

  /* ── FULLSCREEN HINT ── */
  .hint {
    position: fixed; bottom: 62px; right: 72px;
    font-family: var(--font-mono); font-size: 10px;
    color: rgba(255,255,255,.2); letter-spacing: 1px;
    pointer-events: none;
  }
</style>
</head>
